{* VENOM CODES — Scroll to Top Button. Requires: js/scroll-to-top.js *}

<button id="scroll-to-top"
        class="fixed bottom-6 right-6 z-40 flex h-10 w-10 items-center justify-center rounded-full border bg-card shadow-lg opacity-0 scale-75 pointer-events-none"
        style="transition: all 0.2s ease; cursor: pointer;"
        aria-label="Scroll to top">
  <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/>
  </svg>
</button>
