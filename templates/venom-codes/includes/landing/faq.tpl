{* VENOM CODES - FAQ Section. Requires: js/faq-accordion.js *}

<section id="faq" class="venom-section bg-surface-sunken">
  <div class="venom-container">
    <div class="vs-landing-intro">
      <span class="venom-badge vs-landing-badge-spacing">FAQ</span>
      <h2 class="font-display vs-landing-title">
        Frequently Asked Questions
      </h2>
    </div>

    <div class="vs-faq-stack">

      {* FAQ Item 1 *}
      <div data-faq-item class="vs-faq-item">
        <button data-faq-trigger class="vs-faq-trigger">
          <span class="font-display text-sm vs-faq-question">How fast is license activation?</span>
          <svg data-faq-chevron class="h-4 w-4 text-muted-foreground vs-faq-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div data-faq-answer class="faq-answer max-h-0 opacity-0 overflow-hidden">
          <p class="text-sm text-muted-foreground vs-faq-answer-copy">Licenses activate instantly - typically within 30 seconds of purchase. No manual review or approval process is required.</p>
        </div>
      </div>

      {* FAQ Item 2 *}
      <div data-faq-item class="vs-faq-item">
        <button data-faq-trigger class="vs-faq-trigger">
          <span class="font-display text-sm vs-faq-question">Can I upgrade my plan later?</span>
          <svg data-faq-chevron class="h-4 w-4 text-muted-foreground vs-faq-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div data-faq-answer class="faq-answer max-h-0 opacity-0 overflow-hidden">
          <p class="text-sm text-muted-foreground vs-faq-answer-copy">Yes. You can upgrade from Trial to Pro or Ultra at any time. Your existing deployment stays online during the transition with zero downtime.</p>
        </div>
      </div>

      {* FAQ Item 3 *}
      <div data-faq-item class="vs-faq-item">
        <button data-faq-trigger class="vs-faq-trigger">
          <span class="font-display text-sm vs-faq-question">What happens when my license expires?</span>
          <svg data-faq-chevron class="h-4 w-4 text-muted-foreground vs-faq-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div data-faq-answer class="faq-answer max-h-0 opacity-0 overflow-hidden">
          <p class="text-sm text-muted-foreground vs-faq-answer-copy">You'll receive reminders before expiration. If not renewed, your license will gracefully deactivate. Your data and configurations are preserved for 30 days.</p>
        </div>
      </div>

      {* FAQ Item 4 *}
      <div data-faq-item class="vs-faq-item">
        <button data-faq-trigger class="vs-faq-trigger">
          <span class="font-display text-sm vs-faq-question">How do load balancers work?</span>
          <svg data-faq-chevron class="h-4 w-4 text-muted-foreground vs-faq-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div data-faq-answer class="faq-answer max-h-0 opacity-0 overflow-hidden">
          <p class="text-sm text-muted-foreground vs-faq-answer-copy">Pro includes 1 load balancer. Additional ones cost $15/mo each. Ultra includes unlimited load balancers at no extra cost. All provisioned instantly.</p>
        </div>
      </div>

      {* FAQ Item 5 *}
      <div data-faq-item class="vs-faq-item">
        <button data-faq-trigger class="vs-faq-trigger">
          <span class="font-display text-sm vs-faq-question">Is there a refund policy?</span>
          <svg data-faq-chevron class="h-4 w-4 text-muted-foreground vs-faq-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div data-faq-answer class="faq-answer max-h-0 opacity-0 overflow-hidden">
          <p class="text-sm text-muted-foreground vs-faq-answer-copy">Please refer to our Terms of Service for details on our refund and cancellation policy.</p>
        </div>
      </div>

      {* FAQ Item 6 *}
      <div data-faq-item class="vs-faq-item">
        <button data-faq-trigger class="vs-faq-trigger">
          <span class="font-display text-sm vs-faq-question">Do you offer custom plans?</span>
          <svg data-faq-chevron class="h-4 w-4 text-muted-foreground vs-faq-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div data-faq-answer class="faq-answer max-h-0 opacity-0 overflow-hidden">
          <p class="text-sm text-muted-foreground vs-faq-answer-copy">Please contact our team to discuss your specific requirements. We can work with you to find the right solution for your needs.</p>
        </div>
      </div>

    </div>
  </div>
</section>
